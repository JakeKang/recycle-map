{
  "name": "recycle-map",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --reporter=list",
    "perf:smoke": "node scripts/perf-smoke.mjs",
    "perf:smoke:prodlike": "PERF_FORCE_LOCAL_STORE=false PERF_ALLOW_DB_FALLBACK=false node scripts/perf-smoke.mjs",
    "security:audit": "pnpm audit --prod",
    "predeploy:check": "node scripts/predeploy-check.mjs --target=development",
    "predeploy:check:full": "node scripts/predeploy-check.mjs --target=all",
    "predeploy:verify": "pnpm predeploy:check && pnpm smoke:full && pnpm test",
    "predeploy:verify:full": "pnpm predeploy:check:full && pnpm smoke:full && pnpm test",
    "smoke": "vitest run src/app/api/upload/upload-routes.test.ts src/app/api/points/points.route.test.ts src/app/api/points/point-detail.route.test.ts src/app/api/points/point-reviews.route.test.ts src/app/api/points/point-reports.route.test.ts",
    "smoke:full": "pnpm smoke && pnpm test:e2e && pnpm lint && pnpm build"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.21",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "react-leaflet-markercluster": "^5.0.0-rc.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
